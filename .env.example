# =============================================================================
# RMM Service (MeshCentral) - Environment Configuration
# Copy to .env and fill in required values before first deploy.
# =============================================================================

# OPTIONAL: MeshCentral Docker image tag.
MESHCENTRAL_IMAGE_TAG=latest

# REQUIRED: Public hostname for MeshCentral (must match DNS and Apache VirtualHost).
MESHCENTRAL_HOSTNAME=rmm.aimiratech.com

# REQUIRED: Random session key (generated automatically by setup.sh).
# Generate manually: openssl rand -hex 32
MESHCENTRAL_SESSION_KEY=change-me-to-random-64-chars

# OPTIONAL: Absolute path for backup archives.
BACKUP_DIR=/home/aimiratech/rmm-service/backups

# OPTIONAL: Days to retain backup archives before automatic pruning.
BACKUP_RETENTION_DAYS=30